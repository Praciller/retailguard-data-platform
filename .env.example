POSTGRES_USER=retailguard
POSTGRES_PASSWORD=retailguard
POSTGRES_DB=retailguard
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://retailguard:retailguard@localhost:5432/retailguard
